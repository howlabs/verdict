{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|StrReplace",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/hacking-detector.js\" || exit 0",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\hacking-detector.js\" }",
            "timeout": 5,
            "statusMessage": "xiao: scanning for reward hacking..."
          }
        ]
      }
    ]
  }
}